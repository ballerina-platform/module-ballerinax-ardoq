# Represents the Queries record for the operation: listReferences
public type ListReferencesQueries record {
    # Display label for your reference
    string displayText?;
    # The ardoq identifier of the workspace that the target belongs to
    string targetWorkspace?;
    # The ardoq identifier of the workspace that the reference/source belongs to
    string rootWorkspace?;
    # The ardoq identifier of the source
    string 'source?;
    # The type identifier of the reference
    string 'type?;
    # The ardoq identifier of the target
    string target?;
};

# Similar to the _body_ of a `PATCH` request to `/api/v2/references`. The only difference is that the values both `source` and `target` fields may be the batch identifiers of components being created in the same request, or 'Unique By' objects
public type PartialReferenceDocument record {
    # Display label for your reference in views such as the block diagram
    string displayText?;
    # A custom field is a key/value pair that is not intrinsic to the ardoq model
    record {} customFields?;
    anydata? description?;
    # Identify the source component. A component that exists may be identified by an Ardoq Id (oid) or an alias identifier. If the source component is created or upserted in the same batch request, then you must use the `batchId` value associated with that component
    string 'source?;
    # Identify the target component. A component that exists may be identified by an Ardoq Id (oid) or an alias identifier. If the target component is created or upserted in the same batch request, then you must use the `batchId` value associated with that component
    string target?;
};

