    # Color is a style attribute used by the front-end to display the component color in views like the block diagram. By default this will use the color defined by the component-type, but can be overriden by setting it explicitly per-component
    string? color?;
    # Shape is a style attribute used by the front-end to display the component shape in views like the block diagram. By default this will use the shape defined by the component-type, but can be overriden by setting it explicitly per-component. A list of valid values for this attribute should be found by inspecting the style drop-down in the front-end
    string? shape?;
    # A custom field is a key/value pair that is not intrinsic to the ardoq model
    record {} customFields?;
    # The name of the component
    anydata name?;
    # Icon is a style attribute used by the front-end to display the component icon in views like the block diagram. By default this will use the icon defined by the component-type, but can be overriden by setting it explicitly per-component. A list of valid values for this attribute should be found by inspecting the style drop-down in the front-end
    string? icon?;
    anydata? description?;
};

# A reference create operation within a batch request
public type ReferenceCreateOperation record {
    # Similar to the _body_ of a `POST` request to `/api/v2/references`. The only difference is that the values both `source` and `target` fields may be the batch identifiers of components being created in the same request, or 'Unique By' objects
    ReferenceDocument body;
    # A unique user provided identifier
    string batchId?;
};

# Information about the component type
public type ComponentType record {
    # The default display image for the type
    string? image;
    # The parent of the type based on the models hierarchy
    Parent parent?;
    # The display color of the type
    string? color;
    # The default display shape for the type
    string? shape;
    # A list of custom fields supported by the component type
    string[] customFields;
    # The human readable name of the type
    string name;
    # The default display icon for the type
    string? icon;
    # The internal type identifier
    anydata typeId;
};

# A Reference Returned by Ardoq
public type Reference record {
    # Optional display label for your reference in views such as the block diagram
    anydata? displayText?;
    # A custom field is a key/value pair that is not intrinsic to the ardoq model
    record {} customFields;
    # This is a read-only field maintained by the backend to simplify workspace lookups. It is derived from the `target` attribute. A reference's `targetWorkspace` cannot be changed by modifying this attribute
    string targetWorkspace?;
    # This is a read-only field maintained by the backend to simplify workspace lookups. It is derived from the `source` attribute. A reference's `rootWorkspace` cannot be changed by modifying this attribute
    string rootWorkspace?;
    @jsondata:Name {value: "_meta"}
    Metadata1 meta;
    anydata? description?;
    # ID of the reference's source component
    string 'source;
    # The unique Ardoq identifier (oid) of the reference
    @jsondata:Name {value: "_id"}
    string id;
    # Required type ID for the reference. This ID must be a valid type defined by the model that is used by the `rootWorkspace`
    int 'type;
    # Reference versions are used to resolve contention between different users editing the same entity simultaneously. This value should not be modified
    @jsondata:Name {value: "_version"}
    int version;
    # ID of the reference's target component
    string target;
};

# A component upsert operation within a batch request
public type ComponentOperationsUpsert record {
    # A list of fields that uniquely identify the entity. 
    string[] uniqueBy;
