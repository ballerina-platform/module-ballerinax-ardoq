};

# Request body for creating a component
public type CreateComponentRequest record {
    # Image is a style attribute used by the front-end to display the component image in views like the block diagram. By default this will use the image defined by the component-type, but can be overriden by setting it explicitly per-component
    string? image?;
    # The Ardoq identifier (oid) of the parent component
    string? parent?;
    # Shape is a style attribute used by the front-end to display the component shape in views like the block diagram. By default this will use the shape defined by the component-type, but can be overriden by setting it explicitly per-component. A list of valid values for this attribute should be found by inspecting the style drop-down in the front-end
    string? shape?;
    # Color is a style attribute used by the front-end to display the component color in views like the block diagram. By default this will use the color defined by the component-type, but can be overriden by setting it explicitly per-component
    string? color?;
    # A custom field is a key/value pair that is not intrinsic to the ardoq model
    record {} customFields?;
    # The name of the component
    anydata name;
    # Icon is a style attribute used by the front-end to display the component icon in views like the block diagram. By default this will use the icon defined by the component-type, but can be overriden by setting it explicitly per-component. A list of valid values for this attribute should be found by inspecting the style drop-down in the front-end
    string? icon?;
    # The Ardoq identifier (oid) of the workspace that the component belongs to
    string rootWorkspace;
    anydata? description?;
    # Component types are drawn from the type-hierarchy defined by the workspace's metamodel
    anydata typeId;
};

# The Paginated Response
public type PaginatedComponentResponse record {
    @jsondata:Name {value: "_links"}
    Links links;
    Component[] values;
    # Metadata related to the paginated response
    @jsondata:Name {value: "_meta"}
    record {} meta?;
};

# A Workspace Returned by Ardoq
public type Workspace record {
    # The default view that will be shown when opening the workspace
    string? startView?;
    # The name of your workspace. Required
    anydata name;
    @jsondata:Name {value: "_meta"}
    Metadata1 meta;
    anydata? description?;
    # Unique component `id`. Required and read-only
    @jsondata:Name {value: "_id"}
    string id;
    # Versions are used to resolve contention between different users editing the same entity simultaneously
    @jsondata:Name {value: "_version"}
    int version;
    # The views that are configured as default tabs at the top of the workspace
    string[]? views?;
    # A unique human-readible workspace identifier
    string workspaceKey?;
};
