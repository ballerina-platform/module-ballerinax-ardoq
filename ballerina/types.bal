};

# Result of a reference create operation in a batch request
public type CreatedReferenceResult record {
    # The Ardoq identifier (oid) of the entity
    string id;
    # A Reference Returned by Ardoq
    Reference body?;
    # A unique user provided identifier
    string batchId?;
};

# An alias is a user provided string that resolves to an existing component/reference in Ardoq. An alias may be used in place of an Ardoq Id. 
public type Aliases record {
    record {|ComponentAlias...;|} components?;
    record {|ReferenceAlias...;|} references?;
};

# A reference upsert operation within a batch request
public type ReferenceOperationsUpsert record {
    # A list of fields that uniquely identify the entity. 
    string[] uniqueBy;
    # Similar to the _body_ of a `POST` request to `/api/v2/references`. The only difference is that the values both `source` and `target` fields may be the batch identifiers of components being created in the same request, or 'Unique By' objects
    ReferenceDocument body;
    # A unique user provided identifier
    string batchId?;
};

# Represents the Queries record for the operation: updateComponent
public type UpdateComponentQueries record {
    # This parameter is used to manage concurrency control. The value **MUST** be either a positive integer, or the enum `latest`. 
    # | Value | Meaning |
    # |--------|---------|
    # |<nobr>`<integer>`</nobr>| The update **MUST** fail if the `_version` field of the stored entity is not identical to the provided value. |\n|`latest`   | The update should use the current (latest) version of the stored entity. |
    # 
    # For more information about versioning and concurrency control please see the [API guide on Versioning](/api-guides/concepts/versioning/)
    string ifVersionMatch;
};

# The Paginated Response
public type PaginatedWorkspaceResponse record {
    @jsondata:Name {value: "_links"}
    Links links;
    Workspace[] values;
    # Metadata related to the paginated response
    @jsondata:Name {value: "_meta"}
